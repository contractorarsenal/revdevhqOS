# Neon PostgreSQL — pooled connection string (used by the app at runtime)
DATABASE_URL=

# Neon PostgreSQL — direct/unpooled connection string (used for migrations)
DATABASE_URL_UNPOOLED=

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL the auth server runs on (http://localhost:3000 in development)
BETTER_AUTH_URL=

# Public app URL (same as BETTER_AUTH_URL for a single deployment)
NEXT_PUBLIC_APP_URL=
