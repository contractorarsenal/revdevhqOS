# ===== Supabase =====
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used for admin operations (demo seed).
SUPABASE_SERVICE_ROLE_KEY=

# ===== Database (Supabase Postgres) =====
# Project settings → Database → connection string (pooler). Used by the app at runtime.
DATABASE_URL=
# Direct (non-pooled) connection string. Used for migrations. Falls back to DATABASE_URL.
DATABASE_URL_DIRECT=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local development without a database server is possible with the embedded
# dev-only driver:  DATABASE_URL=pglite://.pglite/data
